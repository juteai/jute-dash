{
  "id": "org.pmdroid.microwakeword.local",
  "name": "microWakeWord Local",
  "version": "experimental",
  "kind": "wake-word",
  "transport": {
    "type": "builtin",
    "endpoint": "local-voice-service"
  },
  "capabilities": {
    "offline": true,
    "languages": ["en"]
  },
  "hardware": {
    "cpu": true,
    "gpu": false,
    "coreml": false,
    "cuda": false,
    "raspberryPi": false
  },
  "credentials": [],
  "license": {
    "name": "MIT",
    "url": "https://github.com/pmdroid/microwakeword/blob/main/LICENSE"
  },
  "contribution": {
    "source": "https://github.com/pmdroid/microwakeword",
    "maintainers": ["pmdroid"]
  },
  "wakeWord": {
    "defaultModelId": "okay-nabu",
    "phrase": "Okay Nabu",
    "languages": ["en"],
    "sensitivity": 0.55,
    "models": [
      {
        "id": "okay-nabu",
        "path": "assets/okay_nabu.tflite",
        "phrase": "Okay Nabu",
        "languages": ["en"],
        "sensitivity": 0.55
      }
    ]
  }
}
