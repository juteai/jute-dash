{
  "home": {
    "name": "Jute House",
    "timezone": "Europe/London",
    "locale": "en-GB"
  },
  "server": {
    "listenAddress": "127.0.0.1:8787"
  },
  "mcp": {
    "enabled": false,
    "transport": "streamable-http",
    "listenAddress": "127.0.0.1:8790",
    "path": "/mcp",
    "allowLan": false,
    "auth": {
      "mode": "local-token",
      "envToken": "JUTE_MCP_TOKEN"
    }
  },
  "a2a": {
    "allowLoopback": true,
    "allowedAgentCardURLs": [
      "https://agent.example.com/.well-known/agent-card.json",
      "https://energy.example.com/.well-known/agent-card.json"
    ]
  },
  "display": {
    "theme": "system",
    "colorMode": "system",
    "themeId": "jute-mono",
    "density": "comfortable",
    "motion": "full",
    "background": {
      "kind": "theme",
      "value": "",
      "fit": "cover",
      "position": "center",
      "overlay": "none"
    },
    "widgetChrome": {
      "default": "solid"
    },
    "accentColor": "neutral",
    "idleMode": "ambient"
  },
  "weather": {
    "enabled": true,
    "provider": "open-meteo",
    "locationName": "London",
    "latitude": 51.5072,
    "longitude": -0.1276,
    "temperatureUnit": "celsius",
    "windSpeedUnit": "kmh"
  },
  "voice": {
    "enabled": false,
    "mutedByDefault": true,
    "wakeWordModelId": "",
    "sttProviderId": "",
    "ttsProviderId": "",
    "sttModelId": "",
    "ttsModelId": "",
    "ttsVoiceId": "",
    "preferredAgentId": "",
    "cloudOptIn": false,
    "commandProvidersEnabled": false,
    "sensitiveOutputPolicy": "visual_only_sensitive",
    "followupWindowSeconds": 8,
    "microphoneProfile": ""
  },
  "agents": [
    {
      "id": "house-concierge",
      "name": "House Concierge",
      "description": "General household assistant for summaries, reminders, and routing requests.",
      "cardUrl": "https://agent.example.com/.well-known/agent-card.json",
      "endpointUrl": "https://agent.example.com/a2a/v1",
      "protocolBinding": "JSONRPC",
      "enabled": true,
      "capabilities": ["conversation", "home-summary", "reminders"],
      "mcpScopes": ["dashboard:read", "widgets:read", "skills:read", "skills:context_read", "skills:prompt_read"],
      "auth": {
        "type": "bearer",
        "envToken": "JUTE_HOUSE_CONCIERGE_TOKEN"
      }
    },
    {
      "id": "energy-watch",
      "name": "Energy Watch",
      "description": "Tracks household energy usage and suggests low-friction savings.",
      "cardUrl": "https://energy.example.com/.well-known/agent-card.json",
      "endpointUrl": "https://energy.example.com/a2a/v1",
      "protocolBinding": "JSONRPC",
      "enabled": false,
      "capabilities": ["energy", "forecasting"],
      "mcpScopes": ["dashboard:read", "widgets:read", "skills:read", "skills:context_read"]
    }
  ],
  "rooms": [
    {
      "id": "kitchen",
      "name": "Kitchen",
      "summary": "Comfortable",
      "status": "ok"
    },
    {
      "id": "living-room",
      "name": "Living Room",
      "summary": "Lights on",
      "status": "active"
    },
    {
      "id": "studio",
      "name": "Studio",
      "summary": "Quiet mode",
      "status": "muted"
    }
  ],
  "tiles": [
    {
      "id": "climate",
      "kind": "climate",
      "label": "Climate",
      "value": "21.5 C",
      "detail": "Heating idle"
    },
    {
      "id": "lights",
      "kind": "lighting",
      "label": "Lights",
      "value": "6 on",
      "detail": "Evening scene"
    },
    {
      "id": "security",
      "kind": "security",
      "label": "Security",
      "value": "Armed home",
      "detail": "All doors closed"
    },
    {
      "id": "network",
      "kind": "network",
      "label": "Network",
      "value": "Online",
      "detail": "42 devices"
    }
  ],
  "dashboard": {
    "widgets": [
      {
        "id": "date-time-widget",
        "type": "date-time",
        "title": "Clock",
        "x": 0,
        "y": 0,
        "w": 2,
        "h": 1,
        "visible": true,
        "settings": {
          "chrome": "clear"
        }
      },
      {
        "id": "weather-widget",
        "type": "weather",
        "title": "Local Weather",
        "x": 2,
        "y": 0,
        "w": 2,
        "h": 1,
        "visible": true,
        "settings": {
          "location": "London",
          "latitude": 51.5072,
          "longitude": -0.1276,
          "temperature-unit": "celsius",
          "wind-speed-unit": "kmh"
        }
      },
      {
        "id": "assistant-chat",
        "type": "chat-history",
        "title": "Concierge Chat",
        "x": 0,
        "y": 1,
        "w": 2,
        "h": 2,
        "visible": true
      },
      {
        "id": "hacker-news",
        "type": "rss",
        "title": "Tech News",
        "x": 2,
        "y": 1,
        "w": 2,
        "h": 2,
        "visible": true,
        "settings": {
          "limit": 5,
          "feeds": [
            {
              "url": "https://news.ycombinator.com/rss",
              "name": "Hacker News"
            }
          ]
        }
      },
      {
        "id": "stocks-watchlist",
        "type": "markets",
        "title": "Markets",
        "x": 0,
        "y": 3,
        "w": 2,
        "h": 2,
        "visible": true,
        "settings": {
          "tickers": [
            "AAPL",
            "GOOG",
            { "symbol": "BTC-USD" }
          ]
        }
      }
    ]
  }
}
